{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM"],
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["base/**/*.ts", "scripts/**/*.ts", "main.ts"]
}
